---
# Docker host without nginx proxy for certbot
users:
 bamboo:
  comment: CI Bamboo User
  groups: 'admin'
  ssh_key: "ssh-rsa  bambooagent"

docker_deployment:
  - emr-3-dev

letsencrypt_cert_domains:
  - wokru.openmrs.org
  - sec3.openmrs.org

nginx_vhosts:
  - listen: "80"
    server_name: "wokru.openmrs.org"
    extra_parameters: |
      return 301 https://$host$request_uri;
  - listen: "443 ssl"
    server_name: "wokru.openmrs.org"
    extra_parameters: |
      if ($ai_bot) { return 444; }
      access_log /var/log/nginx/wokru_access.log;
      error_log /var/log/nginx/wokru_error.log;
      ssl_certificate /etc/letsencrypt/live/wokru.openmrs.org/fullchain.pem;
      ssl_certificate_key /etc/letsencrypt/live/wokru.openmrs.org/privkey.pem;
      location ^~ /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
      }
  - listen: "80"
    server_name: "sec3.openmrs.org"
    filename: "sec3.openmrs.org.80.conf"
    extra_parameters: |
      return 301 https://$host$request_uri;
  - listen: "443 ssl"
    server_name: "sec3.openmrs.org"
    extra_parameters: |
      if ($ai_bot) { return 444; }
      access_log /var/log/nginx/sec3_access.log;
      error_log /var/log/nginx/sec3_error.log;
      ssl_certificate /etc/letsencrypt/live/wokru.openmrs.org/fullchain.pem;
      ssl_certificate_key /etc/letsencrypt/live/wokru.openmrs.org/privkey.pem;
      location ^~ /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
      }
      location / {
        proxy_set_header HOST $host;
        proxy_set_header  X-Forwarded-Proto $scheme;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_pass http://127.0.0.1:8090/;
      }


aws_access_key_id: '{{ vault_aws_access_key_id }}'
aws_secret_access_key: '{{ vault_aws_secret_access_key }}'
backup_tag: 'bootstrapped'
